{
  "uid": "stack-agent-overview",
  "title": "stack-agent",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "tags": ["stack-agent"],
  "panels": [
    {
      "id": 1,
      "title": "Poll rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(stackagent_polls_total[5m])",
          "legendFormat": "{{stack}} / {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Deploy rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(stackagent_deploys_total[5m])",
          "legendFormat": "{{stack}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Deploy duration p50",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(stackagent_deploy_duration_seconds_bucket[10m]))",
          "legendFormat": "{{stack}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Deploy duration p95",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(stackagent_deploy_duration_seconds_bucket[10m]))",
          "legendFormat": "{{stack}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Last deploy",
      "type": "table",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {}
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time since last deploy" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "displayName", "value": "Time since last deploy" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [
        {
          "expr": "time() - stackagent_last_deploy_timestamp_seconds",
          "legendFormat": "{{stack}}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "valueLabel": "stack" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "Time since last deploy"
            }
          }
        }
      ]
    }
  ]
}
